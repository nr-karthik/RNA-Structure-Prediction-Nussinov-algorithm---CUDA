cat > .gitignore << 'EOF'
# ── Build artifacts ───────────────────────────────────────────────────────────
build/
*.o
*.a
*.so

# ── Compiled binaries in root ─────────────────────────────────────────────────
benchmark_cpu_omp
core

# ── Compiled binary in src ────────────────────────────────────────────────────
src/nussinov_baseline.exe

# ── Generated GPU output (created at runtime) ─────────────────────────────────
data/gpu_output/

# ── Large bpRNA raw dataset files ─────────────────────────────────────────────
data/bpRNA_1m_90_bpseqFiles.zip
data/bpRNA_1m_90_dbnFiles.zip

# ── Nsight binary files (too large, keep only .txt reports) ───────────────────
reports/*.sqlite
reports/*.nsys-rep

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
EOF